# Copy this file to `.env` in the upstream `openclaw` checkout INSIDE THE TARGET VM ONLY.
# Never commit the real `.env` file.

# -----------------------------------------------------------------------------
# Gateway auth
# -----------------------------------------------------------------------------
# Required when the gateway binds beyond loopback.
OPENCLAW_GATEWAY_TOKEN=<set-a-long-random-token>

# -----------------------------------------------------------------------------
# Model provider keys
# Set at least one provider for the baseline build.
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=<set-real-key-inside-vm-only>
# ANTHROPIC_API_KEY=<set-real-key-inside-vm-only>
# GEMINI_API_KEY=<set-real-key-inside-vm-only>
# OPENROUTER_API_KEY=<set-real-key-inside-vm-only>

# -----------------------------------------------------------------------------
# Optional Docker runtime overrides
# -----------------------------------------------------------------------------
# OPENCLAW_CONFIG_DIR=/home/<vm-user>/.openclaw
# OPENCLAW_WORKSPACE_DIR=/home/<vm-user>/.openclaw/workspace
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_BRIDGE_PORT=18790
#
# In Docker/WSL deployments, keep OPENCLAW_GATEWAY_BIND aligned with the
# working runtime model and enforce local-only or trusted-scope access at the
# host firewall layer if localhost-only publish rules are not supported.
# OPENCLAW_GATEWAY_BIND=lan
# OPENCLAW_TZ=UTC

# Guidance
# 1. Start with only one model provider key plus OPENCLAW_GATEWAY_TOKEN.
# 2. Keep real values only inside the VM.
# 3. Do not enable extra channels or extensions until the base gateway works.
# 4. If the gateway stays beyond loopback, add gateway auth rate limiting in
#    the runtime config and restrict ports 18789/18790 with the host firewall.
