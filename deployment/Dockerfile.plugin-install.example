ARG OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw:latest
FROM ${OPENCLAW_BASE_IMAGE}

# Add a practical Linux baseline for built-in/OpenClaw skills.
USER root
RUN apt-get update &&     DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends       ffmpeg       gh       jq       python3-pip       ripgrep       tmux &&     rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --break-system-packages --no-cache-dir uv

# Stage pinned bundled plugins from source-controlled packlists so the runtime
# loads both Telegram and host-control from the deterministic bundled seam.
COPY --chown=node:node deployment/.build/bundled-plugins/ /app/extensions/
COPY --chown=node:node deployment/workspaces/security-architecture/ /home/node/.openclaw/workspace-security-architecture/

ENV OPENCLAW_BUNDLED_PLUGINS_DIR=/app/extensions
USER node
