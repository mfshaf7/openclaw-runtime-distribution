ARG OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw:latest
FROM ${OPENCLAW_BASE_IMAGE}

# Add a practical Linux baseline for built-in/OpenClaw skills.
USER root
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      ffmpeg \
      gh \
      jq \
      python3-pip \
      ripgrep \
      tmux && \
    rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --break-system-packages --no-cache-dir uv

# Overlay the bundled Telegram runtime with the pinned enhanced Telegram source.
# This preserves bundled plugin precedence while making the runtime reproducible.
COPY --chown=node:node deployment/.build/telegram-bundled-overlay/ /app/dist/extensions/telegram/
COPY --chown=node:node deployment/.build/plugin-artifacts/ /tmp/openclaw-plugin-artifacts/
COPY --chown=node:node deployment/workspaces/security-architecture/ /home/node/.openclaw/workspace-security-architecture/

USER node
RUN set -eu; \
    test -n "$(find /tmp/openclaw-plugin-artifacts -maxdepth 1 -type f -name '*.tgz' -print -quit)"; \
    for plugin in /tmp/openclaw-plugin-artifacts/*.tgz; do \
      openclaw plugins install --force --dangerously-force-unsafe-install "$plugin"; \
    done; \
    rm -rf /tmp/openclaw-plugin-artifacts
